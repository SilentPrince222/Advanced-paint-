# App
NEXT_PUBLIC_APP_NAME=

# Backend API (mocked locally until Phase 4+)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Copy this file to .env and fill in real values.

# postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=verify-full
DATABASE_URL=
# PEM of the AWS RDS global CA bundle — enables sslmode=verify-full; see docs/PHASE0.md
DATABASE_CA_CERT=
# test key sk_test_…
STRIPE_SECRET_KEY=
# 1 short-circuits the Lambda → mock_ charge ids; see SPEC §6.0/§6.2; leave empty for real
MOCK_MODE=
